{
  "name": "designr",
  "productName": "Designr",
  "version": "1.0.0",
  "description": "Design System Builder",
  "author": "Designr",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.designr.app",
    "productName": "Designr",
    "mac": {
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "files": ["*.js", "*.html", "*.css", "preload.js"]
  }
}
